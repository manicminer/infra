---
version: '3.4'

services:
  server:
    image: ${AUTHENTIK_IMAGE:-ghcr.io/goauthentik/server}:${AUTHENTIK_TAG:-2022.9.0}
    restart: always
    command: server
    environment:
      AUTHENTIK_POSTGRESQL__HOST: {{ authentik.postgres_host }}
      AUTHENTIK_POSTGRESQL__USER: {{ authentik.postgres_user }}
      AUTHENTIK_POSTGRESQL__NAME: {{ authentik.postgres_db }}
      AUTHENTIK_POSTGRESQL__PASSWORD: ${PG_PASS}
      # AUTHENTIK_ERROR_REPORTING__ENABLED: "true"
    env_file:
      - .env
    ports:
      - "0.0.0.0:${AUTHENTIK_PORT_HTTP:-9000}:9000"
    user: {{ authentik_uid }}:authentik
    volumes:
      - ./media:/media
      - ./custom-templates:/templates
      - geoip:/geoip
  worker:
    image: ${AUTHENTIK_IMAGE:-ghcr.io/goauthentik/server}:${AUTHENTIK_TAG:-2022.9.0}
    restart: always
    command: worker
    environment:
      AUTHENTIK_POSTGRESQL__HOST: {{ authentik.postgres_host }}
      AUTHENTIK_POSTGRESQL__USER: {{ authentik.postgres_user }}
      AUTHENTIK_POSTGRESQL__NAME: {{ authentik.postgres_db }}
      AUTHENTIK_POSTGRESQL__PASSWORD: ${PG_PASS}
      # AUTHENTIK_ERROR_REPORTING__ENABLED: "true"
    # This is optional, and can be removed. If you remove this, the following will happen
    # - The permissions for the /media folders aren't fixed, so make sure they are 1000:1000
    # - The docker socket can't be accessed anymore
    user: root
    volumes:
      - ./media:/media
      - ./certs:/certs
      - /var/run/docker.sock:/var/run/docker.sock
      - ./custom-templates:/templates
      - geoip:/geoip
    env_file:
      - .env
  geoipupdate:
    image: "maxmindinc/geoipupdate:latest"
    volumes:
      - "geoip:/usr/share/GeoIP"
    environment:
      GEOIPUPDATE_EDITION_IDS: "GeoLite2-City"
      GEOIPUPDATE_FREQUENCY: "8"
    env_file:
      - .env

volumes:
  geoip:
    driver: local

