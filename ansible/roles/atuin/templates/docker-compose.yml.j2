services:
  atuin:
    restart: always
    image: ghcr.io/atuinsh/atuin:{{ atuin_version }}
    command: server start
    ports:
      - 8888:8888
    user: {{ atuin_uid }}:atuin
    volumes:
      - "./config:/config"
    environment:
      ATUIN_HOST: "0.0.0.0"
      ATUIN_OPEN_REGISTRATION: "{{ atuin.registration_enabled }}"
      ATUIN_DB_URI: postgres://{{ atuin.postgres_user }}:${ATUIN_DB_PASSWORD}@{{ atuin.postgres_host }}/{{ atuin.postgres_db }}
      RUST_LOG: info,atuin_server=debug

